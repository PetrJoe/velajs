{
  "name": "velajs",
  "version": "0.2.7",
  "description": "A fullstack framework starter for Next.js, Knex, PostgreSQL, TypeScript, and Tailwind CSS.",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "README.md",
    ".env.example",
    "Dockerfile",
    "docker-compose.yml",
    "eslint.config.mjs",
    "knexfile.ts",
    "middleware.ts",
    "next.config.ts",
    "postcss.config.js",
    "tailwind.config.ts",
    "tsconfig.json",
    "vitest.config.ts",
    "next-env.d.ts",
    "src"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "make": "tsx src/cli/index.ts",
    "make:app": "tsx src/cli/index.ts make:app",
    "make:model": "tsx src/cli/index.ts make:model",
    "make:service": "tsx src/cli/index.ts make:service",
    "make:controller": "tsx src/cli/index.ts make:controller",
    "make:migration": "tsx src/cli/index.ts make:migration",
    "make:validator": "tsx src/cli/index.ts make:validator",
    "make:test": "tsx src/cli/index.ts make:test",
    "make:resource": "tsx src/cli/index.ts make:resource",
    "make:ui": "tsx src/cli/index.ts make:ui",
    "db:migrate": "knex migrate:latest --knexfile knexfile.ts",
    "db:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "db:seed": "knex seed:run --knexfile knexfile.ts",
    "worker": "tsx src/core/jobs/worker.ts"
  },
  "dependencies": {
    "@auth/core": "latest",
    "@next/env": "latest",
    "clsx": "latest",
    "dotenv": "latest",
    "handlebars": "latest",
    "knex": "latest",
    "lucide-react": "^1.24.0",
    "next": "latest",
    "pg": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/pg": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@typescript-eslint/parser": "latest",
    "autoprefixer": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "jsdom": "latest",
    "postcss": "latest",
    "tailwindcss": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
